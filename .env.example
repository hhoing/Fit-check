# ============================================================
# Fit Check — 환경변수 설정 예시
# 이 파일을 복사해서 .env.local 이름으로 저장 후 값을 채워주세요
# cp .env.example .env.local
# ============================================================

# Anthropic Claude API 키 (https://console.anthropic.com 에서 발급)
# 설정하지 않으면 더미 데이터로 동작합니다
ANTHROPIC_API_KEY=

# 출발지 주소 (통근 시간 계산 기준)
# 예: NEXT_PUBLIC_HOME_ADDRESS=서울시 강남구 테헤란로 1
NEXT_PUBLIC_HOME_ADDRESS=

# 네이버 지도 API (통근 시간 실시간 연동 시 필요)
# https://developers.naver.com 에서 발급
# NAVER_MAP_CLIENT_ID=
# NAVER_MAP_CLIENT_SECRET=

# 카카오 REST API (통근 시간 실시간 연동 시 필요)
# https://developers.kakao.com 에서 발급
# KAKAO_REST_API_KEY=
